rules_version = '2';
// ExamHub · Firestore rules
// Paste this into Firebase Console → Firestore Database → Rules.
// Admin email: phuvinhtrannguyen@gmail.com

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    // Treat disabled users as 'guest' for all role checks. The admin-lock
    // feature sets users/{uid}.status = 'disabled'; the client signs them
    // out, but a malicious client can call the REST API with a valid ID
    // token and bypass that. Folding status into role() means every
    // downstream check (isTeacher / isSubAdmin / isAdmin via role()==admin)
    // automatically denies disabled accounts.
    function role() {
      return !isSignedIn() ? 'guest'
        : !exists(/databases/$(database)/documents/users/$(uid())) ? 'guest'
        : userDoc().status == 'disabled' ? 'guest'
        : userDoc().role;
    }
    function isAdmin() {
      // Disabled accounts lose admin access too (same reasoning as above).
      // The hardcoded admin email bypasses role() but must still be active;
      // if the admin doc exists with status='disabled' they go back to guest.
      return isSignedIn()
        && (!exists(/databases/$(database)/documents/users/$(uid()))
            || userDoc().status != 'disabled')
        && (request.auth.token.email == 'phuvinhtrannguyen@gmail.com' || role() == 'admin');
    }
    function isSubAdmin() { return role() == 'subadmin'; }
    function isTeacher() { return role() == 'teacher' || isAdmin() || isSubAdmin(); }
    // True iff the caller is signed in AND not disabled. For writers whose
    // role doesn't matter (submissions/events — any signed-in student may
    // write their own), we still gate on isActive so a disabled account
    // cannot spam the system via REST.
    function isActive() {
      return isSignedIn()
        && (!exists(/databases/$(database)/documents/users/$(uid()))
            || userDoc().status != 'disabled');
    }

    // ---------------- users ----------------
    match /users/{userId} {
      allow read: if isSignedIn() && (userId == uid() || isTeacher() || isAdmin());
      // Users can create their own profile; role must start as guest/student.
      // The admin account (hardcoded email) may self-create with role 'admin'.
      allow create: if isSignedIn() && userId == uid()
        && (
          request.resource.data.role == 'guest'
          || request.resource.data.role == 'student'
          || (request.auth.token.email == 'phuvinhtrannguyen@gmail.com' && request.resource.data.role == 'admin')
        );
      // Self-upgrade guest → teacher is only allowed if the client also writes a
      // `redeemedKey` field AND the referenced teacherKeys doc is already marked
      // `usedBy == uid()`. `redeemTeacherKey()` in index.html does this inside a
      // transaction; a client calling updateDoc directly without consuming a key
      // will fail the get() check below.
      allow update: if isSignedIn() && (
        // Self-edit: may NOT touch admin-controlled fields (role, status, email).
        // status is used for admin account locking (index.html disables a user),
        // so allowing a disabled user to flip it back to 'active' would bypass
        // the lock entirely. email is defended because the client-side
        // isAdmin() previously consulted profile.email — a user could rewrite
        // their own doc's email to the admin address and trick the UI into
        // revealing the admin dashboard. The client was also hardened to use
        // auth.email instead of profile.email, but rule-level defense stays.
        (userId == uid() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role','status','email']))
        || isAdmin()
        // Subadmin may modify other users, but must not touch admins or other
        // subadmins — either before OR after the update. Checking only the
        // incoming role would let a subadmin demote an admin to 'teacher'.
        || (isSubAdmin()
            && resource.data.role != 'admin' && resource.data.role != 'subadmin'
            && request.resource.data.role != 'admin' && request.resource.data.role != 'subadmin')
        || (userId == uid()
            && request.resource.data.role == 'teacher'
            && resource.data.role == 'guest'
            && 'redeemedKey' in request.resource.data
            // Redemption may ONLY flip role + write redeemedKey. Without this
            // hasOnly check a disabled user could redeem a valid key and
            // simultaneously set status back to 'active' in the same write,
            // bypassing the admin-imposed account lock (the self-edit branch
            // catches this, but branch 4 previously did not).
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role','redeemedKey'])
            && exists(/databases/$(database)/documents/teacherKeys/$(request.resource.data.redeemedKey))
            && get(/databases/$(database)/documents/teacherKeys/$(request.resource.data.redeemedKey)).data.usedBy == uid())
      );
      allow delete: if isAdmin();
    }

    // ---------------- teacherKeys ----------------
    match /teacherKeys/{code} {
      // Allow direct `get(teacherKeys/{code})` for every signed-in user so the
      // redemption flow (redeemTeacherKey → getDoc by code) works. Disallow
      // `list` for non-admins — otherwise any signed-in guest could enumerate
      // unused keys via REST and self-escalate to teacher.
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      // Admin may update freely.
      allow update: if isAdmin();
      // Allow key redemption: a signed-in, non-disabled user can mark the
      // key as used by themselves, but only the `usedBy` / `usedAt` fields
      // may change, and only if the key has not expired. Excluding disabled
      // accounts prevents a locked-out user from burning unrelated keys.
      allow update: if isActive()
        && resource.data.usedBy == null
        && request.resource.data.usedBy == uid()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy','usedAt'])
        && (!('expiresAt' in resource.data) || resource.data.expiresAt == null || resource.data.expiresAt > request.time);
    }

    // ---------------- classes ----------------
    // Teacher-ownership branch uses isActive() so a disabled teacher cannot
    // mass-delete or corrupt their own data via the REST API after lockout.
    // isAdmin()/isSubAdmin() already fold status via role(), so those paths
    // don't need extra gating.
    match /classes/{cid} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && request.resource.data.teacherId == uid();
      allow update, delete: if (isActive() && resource.data.teacherId == uid()) || isAdmin();
    }

    // ---------------- students (managed by teacher) ----------------
    match /students/{sid} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && request.resource.data.teacherId == uid();
      allow update, delete: if (isActive() && resource.data.teacherId == uid()) || isAdmin();
    }

    // ---------------- exams ----------------
    // The main exam document holds title/description/questions (stems/options)
    // but NOT the correct answers — those live in the /private subcollection
    // below so the public-read exam doc no longer leaks answer keys via a
    // trivial Firestore REST call on the exams collection.
    match /exams/{eid} {
      allow read: if true; // public read so join link works
      allow create: if isTeacher() && request.resource.data.teacherId == uid();
      allow update, delete: if (isActive() && resource.data.teacherId == uid()) || isAdmin() || isSubAdmin();

      // Correct answers (and anything else sensitive per-exam) live here.
      // Read is still permissive because client-side grading (including the
      // anonymous #join flow) needs the plaintext answers to compute a score
      // without a Cloud Function. Moving answers out of the main exam doc
      // prevents casual leakage via the exams/ REST listing; a proper fix
      // (hiding answers from students entirely) requires server-side grading.
      // Write is restricted to the exam's creator / admin.
      match /private/{docId} {
        allow read: if true;
        allow create, update: if isAdmin()
          || (isTeacher() && get(/databases/$(database)/documents/exams/$(eid)).data.teacherId == uid());
        allow delete: if isAdmin()
          || (isTeacher() && get(/databases/$(database)/documents/exams/$(eid)).data.teacherId == uid());
      }
    }

    // ---------------- submissions ----------------
    // NOTE: client-side grading is used, so score/grading fields are present on create.
    // We validate that (a) examId references a real exam, (b) teacherId matches the exam's
    // teacherId (prevents spoofing another teacher's dashboard), (c) score is in [0,1],
    // and (d) the basic student identity fields are strings. This does not prevent
    // score forgery on its own — for full integrity grading should move to Cloud Functions.
    match /submissions/{sid} {
      allow read: if isSignedIn() && (resource.data.teacherId == uid() || resource.data.studentId == uid() || isAdmin());
      // Require auth — even anonymous students go through Firebase Anonymous
      // Auth (signInAnonymously) when joining via #join/<examId>. Without this,
      // a bot could call the Firestore REST API to spam submissions with score:1.
      allow create: if isActive()
        && request.resource.data.examId is string
        && exists(/databases/$(database)/documents/exams/$(request.resource.data.examId))
        && request.resource.data.teacherId == get(/databases/$(database)/documents/exams/$(request.resource.data.examId)).data.teacherId
        // Bind studentId to the caller's uid — mirrors the events rule.
        // Without this, a malicious signed-in student could POST a submission
        // with studentId="alice-uid" and an arbitrary score (0 or 1) via the
        // Firestore REST API, framing Alice with fake results.
        && request.resource.data.studentId == uid()
        && request.resource.data.studentName is string
        && request.resource.data.studentName.size() > 0
        && request.resource.data.studentName.size() <= 120
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1;
      allow update, delete: if (isActive() && resource.data.teacherId == uid()) || isAdmin();
    }

    // ---------------- events (violations, logs) ----------------
    match /events/{eid} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.teacherId == uid());
      // Require auth, validate that the event belongs to a real exam + its
      // teacher, AND bind studentId to the caller's uid. Without the last
      // clause, a malicious signed-in student could forge violation events
      // attributed to another student (e.g. Bob writes count:99 events with
      // studentId:"alice-uid"), framing them on the teacher's dashboard.
      // The #join flow now always signs users in with a real account, so
      // studentId == uid() is enforceable across all legitimate callers.
      allow create: if isActive()
        && request.resource.data.examId is string
        && exists(/databases/$(database)/documents/exams/$(request.resource.data.examId))
        && request.resource.data.teacherId == get(/databases/$(database)/documents/exams/$(request.resource.data.examId)).data.teacherId
        && request.resource.data.studentId == uid();
      allow update, delete: if isAdmin();
    }

    // ---------------- requests (teacher → admin) ----------------
    match /requests/{rid} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.uid == uid());
      // Disabled users cannot spam request docs either — consistent with
      // submissions/events.create gating.
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------- global config ----------------
    // Only teachers / admins may read the Gemini API key; students must not see it.
    match /global/{docId} {
      allow read: if isTeacher();
      allow write: if isAdmin();
    }
  }
}
