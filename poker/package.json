{
  "name": "cu-bung-poker",
  "private": true,
  "version": "0.1.0",
  "description": "Realtime poker game with virtual currency 'cu bung' (no real money).",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:client",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server run start",
    "test": "npm --workspace server run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
